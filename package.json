{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "playground",
    "version": "1.1.3",
    "private": true,
    "description": "Quickly test code snippets in your browser, whenever you need.",
    "license": "Apache-2.0",
    "author": "SodiumLabs",
    "homepage": "https://github.com/sodium-labs/playground#readme",
    "bugs": {
        "url": "https://github.com/sodium-labs/playground/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sodium-labs/playground.git"
    },
    "scripts": {
        "dev": "dotenv -- next dev",
        "build": "npm run lint && next build",
        "start": "dotenv -- next start",
        "lint": "oxlint && oxfmt --check",
        "fmt": "oxfmt",
        "format": "prettier . --write"
    },
    "dependencies": {
        "@monaco-editor/react": "^4.7.0",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-select": "^2.1.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.1.2",
        "@radix-ui/react-toggle": "^1.1.10",
        "@radix-ui/react-toggle-group": "^1.1.11",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv-cli": "^11.0.0",
        "lucide-react": "^0.483.0",
        "motion": "^12.29.2",
        "next": "^16.1.5",
        "next-themes": "^0.4.6",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-resizable-panels": "^2.1.7",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.4.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "zod": "^3.24.2",
        "zustand": "^5.0.10"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.18",
        "@types/node": "^25.0.10",
        "@types/react": "^19.2.10",
        "@types/react-dom": "^19.2.3",
        "oxfmt": "^0.27.0",
        "oxlint": "^1.42.0",
        "tailwindcss": "^4.1.18"
    }
}
